# Trading Guardian - Environment Variables
# Copy this to .env and fill in your credentials

# Alpaca API Credentials
ALPACA_API_KEY=YOUR_API_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_KEY_HERE
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── DEXTER TOOLS INTEGRATION ───────────────────────

# Financial Datasets API (REQUIRED for Dexter Tools)
# Get your FREE key from: https://financialdatasets.ai
FINANCIAL_DATASETS_API_KEY=YOUR_FINANCIAL_DATASETS_API_KEY_HERE

# ─── SMART-ROUTER / LITELLM ─────────────────────────

# Smart Router Model (uses litellm - NO Claude/OpenAI direct)
# Options: smart-router, z-ai/glm-4.5-air:free, hf:MiniMaxAI/MiniMax-M2.5
SMART_ROUTER_MODEL=smart-router

# ─── SYSTEM CONFIG ──────────────────────────────────

# Log Level
LOG_LEVEL=INFO

# Health Check Interval (seconds)
HEALTH_CHECK_INTERVAL=60

# AutoResearch Cycle Interval (seconds)
AUTORESEARCH_INTERVAL=3600

# Guardian Settings
GUARDIAN_LOG_LEVEL=INFO
GUARDIAN_AUTO_RESEARCH_ENABLED=true
GUARDIAN_VALIDATION_ENABLED=true
GUARDIAN_AUTO_ROLLBACK=true

# Notification Settings (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AutoResearch Settings
AUTORESEARCH_INTERVAL=3600
AUTORESEARCH_MAX_EXPERIMENTS=10
